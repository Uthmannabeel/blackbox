{
  "name": "blackbox",
  "version": "0.1.0",
  "private": true,
  "description": "BlackBox — an SRE incident-response agent whose memory survives the crash. Built on CockroachDB (regional-by-row distributed vector memory + Managed MCP) and AWS Bedrock.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "web"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --dry",
    "db:schema": "npm run build && node packages/memory/dist/scripts/applySchema.js",
    "db:seed": "npm run build && node packages/memory/dist/scripts/seed.js",
    "db:seed:scale": "npm run build && node packages/memory/dist/scripts/seedScale.js",
    "agent:dev": "npm run build && node packages/agent/dist/cli.js",
    "dev": "npm run dev -w @blackbox/web",
    "dev:mock": "node scripts/mockdev.mjs",
    "web:build": "npm run build -w @blackbox/web",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
