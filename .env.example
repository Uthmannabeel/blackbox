# ---- CockroachDB Cloud ----
# Full connection string from the CockroachDB Cloud console (sql user).
# Multi-region cluster; the driver connects to the nearest gateway region.
DATABASE_URL="postgresql://blackbox:<password>@<host>:26257/blackbox?sslmode=verify-full"

# CockroachDB Cloud Managed MCP Server endpoint + service-account API key.
CRDB_MCP_URL="https://<cluster>.cockroachlabs.cloud/mcp"
CRDB_MCP_API_KEY="<service-account-api-key>"

# ---- AWS Bedrock ----
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="<key>"
AWS_SECRET_ACCESS_KEY="<secret>"
# Reasoning model (Claude on Bedrock) and embedding model (Titan v2, 1024-dim).
# Use the exact model ID shown in YOUR Bedrock console's model catalog.
# If Converse errors with "on-demand throughput isn't supported", prepend the
# region prefix (inference profile), e.g. "us.anthropic.claude-sonnet-4-6".
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-6"
BEDROCK_EMBED_MODEL_ID="amazon.titan-embed-text-v2:0"

# ---- App ----
LOG_LEVEL="info"
# Set to 1 to run fully offline (fake embeddings + in-memory store + scripted
# agent) with no CockroachDB/Bedrock calls. Leave unset/0 for real infra.
# BLACKBOX_MOCK="1"
